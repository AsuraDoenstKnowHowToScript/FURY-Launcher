<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sty="using:FluentAvalonia.Styling"
             x:Class="Launcher.App.App"
             RequestedThemeVariant="Dark">

    <!-- Design tokens (colours/radii/spacing/fonts) available app-wide. -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/Tokens.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <!-- Order: Fluent base (via FluentAvalonia) -> typography -> control styles.
         FluentAvaloniaTheme is a complete Fluent theme; the purple accent is
         injected via CustomAccentColor so its controls inherit it. -->
    <Application.Styles>
        <sty:FluentAvaloniaTheme PreferSystemTheme="False" CustomAccentColor="#6D28D9"/>
        <StyleInclude Source="/Styles/Typography.axaml"/>
        <StyleInclude Source="/Styles/Controls.axaml"/>
    </Application.Styles>
</Application>
