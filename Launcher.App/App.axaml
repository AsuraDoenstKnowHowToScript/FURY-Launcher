<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Launcher.App.App">
    <!-- SimpleTheme = the barest built-in Avalonia theme (raw/native look).
         No custom styles or themes, per the "PyQt seco" philosophy. -->
    <Application.Styles>
        <SimpleTheme />
    </Application.Styles>
</Application>
