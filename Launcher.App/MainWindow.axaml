<ui:AppWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="using:FluentAvalonia.UI.Windowing"
        xmlns:uic="using:FluentAvalonia.UI.Controls"
        xmlns:icon="using:IconPacks.Avalonia.Lucide"
        xmlns:models="using:Launcher.Core.Models"
        xmlns:vm="using:Launcher.App.ViewModels"
        xmlns:behaviors="using:Launcher.App.Behaviors"
        x:Class="Launcher.App.MainWindow"
        Width="1280" Height="860"
        MinWidth="1120" MinHeight="740"
        Background="{DynamicResource BgBase}"
        Foreground="{DynamicResource TextPrimary}"
        FontWeight="SemiBold"
        Icon="/Assets/fury-logo.png"
        Title="FURY Launcher">

    <!-- Visible text is set from Launcher.Core.Localization at runtime (ApplyLanguage). -->
    <Grid>
    <DockPanel>

        <!-- Auto-update banner: hidden until a newer release is found on GitHub. -->
        <Border x:Name="UpdateBanner" DockPanel.Dock="Top" IsVisible="False"
                Background="{DynamicResource BgElevated}" BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,0,1" Padding="16,11">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <Border Grid.Column="0" Width="34" Height="34" CornerRadius="999"
                        Background="{DynamicResource AccentSubtle}" Margin="0,0,12,0" VerticalAlignment="Center">
                    <Image Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Source="{icon:LucideImage Kind=ArrowUp, Brush={StaticResource Accent}}"/>
                </Border>
                <TextBlock x:Name="UpdateBannerText" Grid.Column="1" Foreground="{DynamicResource TextPrimary}"
                           FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap"/>
                <Button x:Name="UpdateButton" Grid.Column="2" Classes="primary" Content="Update"
                        Padding="16,7" Margin="12,0,8,0"/>
                <Button x:Name="UpdateDismissButton" Grid.Column="3" Classes="ghost" Content="Later"
                        Padding="12,7"/>
            </Grid>
        </Border>

        <!-- Toggle button hidden: its glyph comes from a symbol font that tofus on
             Windows 10, and the content is set locally in the template so a style
             override can't win. A 4-item pane reads fine always-open. -->
        <uic:NavigationView x:Name="NavView" PaneDisplayMode="Left" OpenPaneLength="220"
                            IsSettingsVisible="False" IsBackButtonVisible="False"
                            IsPaneToggleButtonVisible="False">

            <uic:NavigationView.PaneHeader>
                <StackPanel Margin="10,12,8,16" Spacing="1">
                    <TextBlock Text="FURY" FontFamily="{DynamicResource FontUi}" FontSize="26"
                               FontWeight="Bold" Foreground="{DynamicResource BrandGradient}"/>
                    <TextBlock x:Name="NavVersion" Classes="Mono" Text="" FontSize="12"
                               Foreground="{DynamicResource TextMuted}"/>
                </StackPanel>
            </uic:NavigationView.PaneHeader>

            <uic:NavigationView.MenuItems>
                <uic:NavigationViewItem x:Name="NavHome" Content="Home">
                    <uic:NavigationViewItem.IconSource>
                        <uic:ImageIconSource Source="{icon:LucideImage Kind=LayoutGrid, Brush={StaticResource TextSecondary}}"/>
                    </uic:NavigationViewItem.IconSource>
                </uic:NavigationViewItem>
                <uic:NavigationViewItem x:Name="NavMods" Content="Mods">
                    <uic:NavigationViewItem.IconSource>
                        <uic:ImageIconSource Source="{icon:LucideImage Kind=Package, Brush={StaticResource TextSecondary}}"/>
                    </uic:NavigationViewItem.IconSource>
                </uic:NavigationViewItem>
                <uic:NavigationViewItem x:Name="NavAccounts" Content="Accounts">
                    <uic:NavigationViewItem.IconSource>
                        <uic:ImageIconSource Source="{icon:LucideImage Kind=User, Brush={StaticResource TextSecondary}}"/>
                    </uic:NavigationViewItem.IconSource>
                </uic:NavigationViewItem>
            </uic:NavigationView.MenuItems>

            <uic:NavigationView.FooterMenuItems>
                <uic:NavigationViewItem x:Name="NavSettings" Content="Settings">
                    <uic:NavigationViewItem.IconSource>
                        <uic:ImageIconSource Source="{icon:LucideImage Kind=Settings, Brush={StaticResource TextSecondary}}"/>
                    </uic:NavigationViewItem.IconSource>
                </uic:NavigationViewItem>
            </uic:NavigationView.FooterMenuItems>

            <!-- One content host; sections toggle visibility from NavView.SelectionChanged. -->
            <Grid Margin="0">

                <!-- ============================ HOME (instances + play) ============================ -->
                <Grid x:Name="HomePanel" Margin="24">
                    <DockPanel>
                        <!-- Header: title + instance-level actions -->
                        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                            <TextBlock Grid.Column="0" x:Name="LblInstances" Classes="Title"
                                       Text="Instances" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button x:Name="ImportButton" Classes="secondary">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock x:Name="ImportButtonLabel" Text="Import" VerticalAlignment="Center"/>
                                        <TextBlock Text="&#x25BE;" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>
                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuItem Header="Import .frpack" Click="OnImportPack"/>
                                            <MenuItem Header="Import .mrpack" Click="OnImportMrpack"/>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                                <Button x:Name="RefreshInstancesButton" Classes="secondary" Content="Refresh"/>
                                <Button x:Name="AddInstanceButton" Classes="primary">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Image Width="16" Height="16" VerticalAlignment="Center" Source="{icon:LucideImage Kind=Plus, Brush={StaticResource OnAccent}}"/>
                                        <TextBlock x:Name="AddInstanceLabel" Text="New instance" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Hero: the selected instance + the big PLAY button, promoted to a top
                             banner so playing is the first thing the page is about. The violet
                             sweep is inline so it beats the card style's flat background. -->
                        <Border DockPanel.Dock="Top" Classes="card" x:Name="HeroCard" Margin="0,0,0,16" Padding="20,18"
                                BoxShadow="0 8 30 0 #386D28D9">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                    <GradientStop Offset="0" Color="#2B1E4E"/>
                                    <GradientStop Offset="0.5" Color="#1C1728"/>
                                    <GradientStop Offset="1" Color="#16141E"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="HeroName" Classes="Display" Text="—" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="HeroMeta" Classes="Caption"
                                                   Foreground="{DynamicResource TextSecondary}" Text=""/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <!-- Frequent utilities stay visible; rare/destructive go in the overflow. -->
                                        <Button x:Name="EditInstanceButton" Classes="secondary" Content="Edit" MinHeight="48"/>
                                        <Button x:Name="OpenFolderButton" Classes="secondary" Content="Folder" MinHeight="48"/>
                                        <Button x:Name="MoreActionsButton" Classes="secondary" MinHeight="48"
                                                Content="&#x2026;" Padding="14,0" ToolTip.Tip="More">
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <MenuItem Header="Export" Click="OnExportPack"/>
                                                    <MenuItem Header="Delete" Click="OnDeleteInstance"/>
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                        <!-- Play cluster: separated from utilities so PLAY reads as the primary action. -->
                                        <Button x:Name="StopButton" Classes="secondary" Content="Stop" MinHeight="48" Margin="16,0,0,0"/>
                                        <Button x:Name="PlayButton" Classes="primary" MinHeight="52" Padding="40,0">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <Image Width="20" Height="20" VerticalAlignment="Center" Source="{icon:LucideImage Kind=Play, Brush={StaticResource OnAccent}}"/>
                                                <TextBlock x:Name="PlayButtonLabel" Text="PLAY" FontSize="18" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <TextBlock x:Name="LblPlayingAs" Text="Playing as" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondary}"/>
                                    <!-- Read-only chip: the active account. Clicking it jumps to the Accounts tab,
                                         the single place you pick who plays. -->
                                    <Button x:Name="ActiveAccountChip" Classes="secondary" Padding="8,6">
                                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                            <Border Width="30" Height="30" CornerRadius="7" ClipToBounds="True"
                                                    Background="{DynamicResource BgElevated}">
                                                <Panel>
                                                    <Image x:Name="ActiveAccountFallback" Width="16" Height="16"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Source="{icon:LucideImage Kind=User, Brush={StaticResource TextMuted}}"/>
                                                    <Image x:Name="ActiveAccountFace" Stretch="Uniform"
                                                           RenderOptions.BitmapInterpolationMode="None"/>
                                                    <Image x:Name="ActiveAccountHat" Stretch="Uniform"
                                                           RenderOptions.BitmapInterpolationMode="None"/>
                                                </Panel>
                                            </Border>
                                            <TextBlock x:Name="ActiveAccountName" Text="—" VerticalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>
                                    <!-- Hidden: kept in sync with the card grid so play logic is unchanged. -->
                                    <ComboBox x:Name="PlayInstanceCombo" IsVisible="False" Width="0"/>
                                </StackPanel>
                                <!-- Only shown while a launch is actually downloading; hidden at rest so
                                     the empty track isn't a stray gray line under the hero. -->
                                <Grid x:Name="ProgressRow" ColumnDefinitions="*,Auto" VerticalAlignment="Center"
                                      IsVisible="False">
                                    <ProgressBar Grid.Column="0" x:Name="DownloadProgress" Minimum="0" Maximum="1" Height="8"/>
                                    <TextBlock Grid.Column="1" x:Name="DownloadPercent" Classes="Caption" Text=""
                                               MinWidth="40" TextAlignment="Right" VerticalAlignment="Center"
                                               Margin="10,0,0,0" Foreground="{DynamicResource TextSecondary}"/>
                                </Grid>
                                <TextBlock x:Name="PlayStatus" Classes="Caption" Text="" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                        </Border>

                        <!-- Log drawer: collapsed by default; opens automatically on error. -->
                        <Expander x:Name="LogDrawer" DockPanel.Dock="Bottom" IsExpanded="False"
                                  Margin="0,12,0,0" HorizontalAlignment="Stretch">
                            <Expander.Header>
                                <TextBlock x:Name="LblLog" Text="Log"/>
                            </Expander.Header>
                            <TextBox x:Name="LogBox" Classes="Mono" Height="180" AcceptsReturn="True" IsReadOnly="True"
                                     TextWrapping="NoWrap" VerticalContentAlignment="Top"/>
                        </Expander>

                        <!-- Instance cards grid (fills remaining space) -->
                        <Grid>
                            <ScrollViewer behaviors:SmoothScroll.Enabled="True" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                                <ListBox x:Name="InstancesList" Background="Transparent" BorderThickness="0" Padding="0">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.Styles>
                                        <Style Selector="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,12,12"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Style>
                                        <!-- Selected card: 1px accent border + subtle tint, not a full purple fill. -->
                                        <Style Selector="ListBoxItem:selected Border.card">
                                            <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                            <Setter Property="Background" Value="{DynamicResource AccentSubtle}"/>
                                        </Style>
                                    </ListBox.Styles>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:Instance">
                                            <Border Classes="card flat" Width="212" Padding="16">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Classes="Subtitle" Text="{Binding Name}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Border Background="{DynamicResource BgElevated}" CornerRadius="999"
                                                            BorderThickness="1"
                                                            BorderBrush="{Binding Loader, Converter={StaticResource LoaderColor}}"
                                                            Padding="9,3" HorizontalAlignment="Left">
                                                        <TextBlock Classes="Caption"
                                                                   Foreground="{Binding Loader, Converter={StaticResource LoaderColor}}"
                                                                   Text="{Binding Loader}"/>
                                                    </Border>
                                                    <TextBlock Classes="Caption" Foreground="{DynamicResource TextMuted}"
                                                               Text="{Binding McVersion}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </ScrollViewer>
                            <StackPanel x:Name="InstancesEmptyState" IsVisible="False"
                                        VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                                <Border Width="76" Height="76" CornerRadius="999" HorizontalAlignment="Center"
                                        Background="{DynamicResource BgElevated}">
                                    <Image Width="34" Height="34" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Source="{icon:LucideImage Kind=LayoutGrid, Brush={StaticResource TextMuted}}"/>
                                </Border>
                                <TextBlock x:Name="EmptyStateText" Text="No instances yet"
                                           HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                                <Button x:Name="EmptyStateNewButton" Classes="primary" Content="＋ New instance"
                                        HorizontalAlignment="Center" Padding="18,10" FontSize="15"/>
                            </StackPanel>
                        </Grid>
                    </DockPanel>

                    <!-- Create / edit instance overlay (hidden until +New or Edit) -->
                    <Grid x:Name="InstanceOverlay" IsVisible="False" Background="#B3000000">
                        <Border Classes="card" Width="520" MaxHeight="660"
                                VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" x:Name="OverlayTitle" Classes="Title"
                                           Text="New instance" Margin="0,0,0,14"/>
                                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
                                    <Button x:Name="CancelInstanceButton" Classes="secondary" Content="Cancel"/>
                                    <Button x:Name="NewInstanceButton" Classes="primary" Content="Create"/>
                                    <Button x:Name="SaveInstanceButton" Classes="primary" Content="Save"/>
                                </StackPanel>
                                <ScrollViewer>
                                    <StackPanel Spacing="14">
                                        <TextBlock x:Name="LblSecGeneral" Classes="Subtitle" Text="General"/>
                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="LblName" Text="Name" Foreground="{DynamicResource TextSecondary}"/>
                                            <TextBox x:Name="NameBox"/>
                                            <TextBlock x:Name="LblMcVersion" Text="Minecraft version" Foreground="{DynamicResource TextSecondary}"/>
                                            <ComboBox x:Name="McVersionCombo" HorizontalAlignment="Stretch"/>
                                            <TextBlock x:Name="LblLoader" Text="Loader" Foreground="{DynamicResource TextSecondary}"/>
                                            <ComboBox x:Name="LoaderCombo" HorizontalAlignment="Stretch"/>
                                        </StackPanel>

                                        <TextBlock x:Name="LblSecMemory" Classes="Subtitle" Text="Memory &amp; Java"/>
                                        <StackPanel Spacing="6">
                                            <Grid ColumnDefinitions="*,12,*">
                                                <StackPanel Grid.Column="0" Spacing="6">
                                                    <TextBlock x:Name="LblMinRam" Text="Min RAM (MB)" Foreground="{DynamicResource TextSecondary}"/>
                                                    <TextBox x:Name="MinRamBox" Text="512"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Spacing="6">
                                                    <TextBlock x:Name="LblMaxRam" Text="Max RAM (MB)" Foreground="{DynamicResource TextSecondary}"/>
                                                    <TextBox x:Name="MaxRamBox" Text="2048"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock x:Name="LblJvmArgs" Text="JVM arguments (space-separated)" Foreground="{DynamicResource TextSecondary}"/>
                                            <TextBox x:Name="JvmArgsBox" Classes="Mono"/>
                                            <TextBlock x:Name="LblJavaPath" Text="Java path (empty = managed)" Foreground="{DynamicResource TextSecondary}"/>
                                            <ComboBox x:Name="JavaCombo" HorizontalAlignment="Stretch" Margin="0,0,0,4"/>
                                            <DockPanel>
                                                <Button x:Name="BrowseJavaButton" Content="..." DockPanel.Dock="Right" Margin="6,0,0,0"/>
                                                <TextBox x:Name="JavaPathBox" Classes="Mono"/>
                                            </DockPanel>
                                        </StackPanel>

                                        <TextBlock x:Name="InstanceStatus" Text="" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- =============================== MODS =============================== -->
                <DockPanel x:Name="ModsPanel" IsVisible="False" Margin="24">
                    <StackPanel DockPanel.Dock="Top" Spacing="10" Margin="0,0,0,12">
                        <!-- One toolbar row: content-type segments on the left, the instance
                             context on the right — no stacked rows eating vertical space. -->
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" Background="{DynamicResource BgElevated}" CornerRadius="12"
                                    Padding="3" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="2">
                                    <RadioButton x:Name="SegMods" Classes="segment" GroupName="contentseg"
                                                 Content="Mods" IsChecked="True"/>
                                    <RadioButton x:Name="SegShaders" Classes="segment" GroupName="contentseg"
                                                 Content="Shaders"/>
                                    <RadioButton x:Name="SegDatapacks" Classes="segment" GroupName="contentseg"
                                                 Content="Datapacks"/>
                                </StackPanel>
                            </Border>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock x:Name="LblModInstance" Text="Instance:" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock x:Name="ModsInstanceName" Text="—" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"/>
                                <Button x:Name="RefreshModsButton" Classes="secondary" Content="Refresh"/>
                                <ComboBox x:Name="ModInstanceCombo" IsVisible="False" Width="0"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel x:Name="ModsVanillaPanel" Orientation="Horizontal" Spacing="8" IsVisible="False">
                            <TextBlock x:Name="ModsVanillaWarning" Text="" TextWrapping="Wrap"
                                       Foreground="{DynamicResource Danger}" VerticalAlignment="Center" MaxWidth="640"/>
                            <Button x:Name="NewModdedInstanceButton" Classes="primary" Content="Create modded instance"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Search is the main event: give it the wider column. -->
                    <Grid ColumnDefinitions="5*,14,7*">
                        <Border Grid.Column="0" Background="{DynamicResource BgSurface}"
                                BorderBrush="{DynamicResource BorderSubtle}"
                                BorderThickness="1" CornerRadius="14">
                            <DockPanel>
                                <!-- Header: title + purple count badge + filter box -->
                                <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,Auto,*" Margin="14,12">
                                    <TextBlock x:Name="LblInstalledMods" Grid.Column="0" Classes="Subtitle"
                                               Text="Mods" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Background="{DynamicResource BgElevated}" CornerRadius="999"
                                            Padding="9,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="ModsCountBadge" Classes="Caption" Text="0"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                    </Border>
                                    <TextBox Grid.Column="2" x:Name="ModsFilterBox" MaxWidth="220"
                                             HorizontalAlignment="Right" Margin="12,0,0,0"
                                             Watermark="Filter installed..."/>
                                </Grid>
                                <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource BorderSubtle}"/>
                                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="14,10,14,12">
                                    <Button x:Name="AddModButton" Content="Add jar"/>
                                </StackPanel>
                                <Grid Margin="10,8,10,4">
                                <!-- Plain ItemsControl (no virtualization, no selection): each card is
                                     created once and never recycled, so hover/toggle can't blink it. -->
                                <ScrollViewer behaviors:SmoothScroll.Enabled="True"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                                    <ItemsControl x:Name="ModsList" Background="Transparent">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:InstalledModVm">
                                                <Border Classes="card flat" Padding="10" MinHeight="84" Margin="0,0,0,8">
                                                    <Grid ColumnDefinitions="Auto,10,*,10,Auto,6,Auto">
                                                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="10"
                                                                VerticalAlignment="Center"
                                                                Background="{DynamicResource BgElevated}" ClipToBounds="True">
                                                            <Panel>
                                                                <Image Width="22" Height="22"
                                                                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                     IsVisible="{Binding !HasIcon}" Source="{icon:LucideImage Kind=Package, Brush={StaticResource TextMuted}}"/>
                                                                <Image Source="{Binding Icon}" Stretch="UniformToFill"
                                                                       IsVisible="{Binding HasIcon}"/>
                                                            </Panel>
                                                        </Border>
                                                        <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <TextBlock Classes="Subtitle" Text="{Binding Title}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Classes="Caption" VerticalAlignment="Center"
                                                                           Foreground="{DynamicResource TextMuted}"
                                                                           Text="{Binding Version}" IsVisible="{Binding HasVersion}"/>
                                                            </StackPanel>
                                                            <TextBlock Classes="Caption" Text="{Binding Description}"
                                                                       Foreground="{DynamicResource TextMuted}"
                                                                       IsVisible="{Binding HasDescription}"
                                                                       TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <ToggleButton Grid.Column="4" Classes="switch"
                                                                      VerticalAlignment="Center"
                                                                      IsChecked="{Binding Enabled}"/>
                                                        <Button Grid.Column="6" Classes="ghost" VerticalAlignment="Center"
                                                                Padding="8" Click="OnRemoveModClick" ToolTip.Tip="Remove">
                                                            <Image Width="16" Height="16" Source="{icon:LucideImage Kind=Trash2, Brush={StaticResource TextMuted}}"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <StackPanel x:Name="ModsEmptyState" IsVisible="False"
                                            VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                    <Border Width="64" Height="64" CornerRadius="999" HorizontalAlignment="Center"
                                            Background="{DynamicResource BgElevated}">
                                        <Image Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Source="{icon:LucideImage Kind=Package, Brush={StaticResource TextMuted}}"/>
                                    </Border>
                                    <TextBlock x:Name="ModsEmptyText" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondary}" Text="No mods installed"/>
                                </StackPanel>
                                </Grid>
                            </DockPanel>
                        </Border>

                        <DockPanel Grid.Column="2">
                            <!-- Search source. CurseForge is temporarily disabled ("coming soon")
                                 while its integration is finished. Brand icons go here once the real
                                 logo assets (Assets/modrinth.*, Assets/curseforge.*) are added. -->
                            <Border DockPanel.Dock="Top" Background="{DynamicResource BgElevated}" CornerRadius="10"
                                    Padding="3" HorizontalAlignment="Left" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" Spacing="2">
                                    <RadioButton x:Name="SrcModrinth" Classes="segment" GroupName="contentsrc" IsChecked="True">
                                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <Viewbox Width="14" Height="14" VerticalAlignment="Center">
                                                <Path Fill="#1BD96A" Data="M12.252.004a11.78 11.768 0 0 0-8.92 3.73a11 11 0 0 0-2.17 3.11a11.37 11.359 0 0 0-1.16 5.169c0 1.42.17 2.5.6 3.77c.24.759.77 1.899 1.17 2.529a12.3 12.298 0 0 0 8.85 5.639c.44.05 2.54.07 2.76.02c.2-.04.22.1-.26-1.7l-.36-1.37l-1.01-.06a8.5 8.489 0 0 1-5.18-1.8a5.3 5.3 0 0 1-1.3-1.26c0-.05.34-.28.74-.5a37.572 37.545 0 0 1 2.88-1.629c.03 0 .5.45 1.06.98l1 .97l2.07-.43l2.06-.43l1.47-1.47c.8-.8 1.48-1.5 1.48-1.52c0-.09-.42-1.63-.46-1.7c-.04-.06-.2-.03-1.02.18c-.53.13-1.2.3-1.45.4l-.48.15l-.53.53l-.53.53l-.93.1l-.93.07l-.52-.5a2.7 2.7 0 0 1-.96-1.7l-.13-.6l.43-.57c.68-.9.68-.9 1.46-1.1c.4-.1.65-.2.83-.33c.13-.099.65-.579 1.14-1.069l.9-.9l-.7-.7l-.7-.7l-1.95.54c-1.07.3-1.96.53-1.97.53c-.03 0-2.23 2.48-2.63 2.97l-.29.35l.28 1.03c.16.56.3 1.16.31 1.34l.03.3l-.34.23c-.37.23-2.22 1.3-2.84 1.63c-.36.2-.37.2-.44.1c-.08-.1-.23-.6-.32-1.03c-.18-.86-.17-2.75.02-3.73a8.84 8.84 0 0 1 7.9-6.93c.43-.03.77-.08.78-.1c.06-.17.5-2.999.47-3.039c-.01-.02-.1-.02-.2-.03Zm3.68.67c-.2 0-.3.1-.37.38c-.06.23-.46 2.42-.46 2.52c0 .04.1.11.22.16a8.51 8.499 0 0 1 2.99 2a8.38 8.379 0 0 1 2.16 3.449a6.9 6.9 0 0 1 .4 2.8c0 1.07 0 1.27-.1 1.73a9.4 9.4 0 0 1-1.76 3.769c-.32.4-.98 1.06-1.37 1.38c-.38.32-1.54 1.1-1.7 1.14c-.1.03-.1.06-.07.26c.03.18.64 2.56.7 2.78l.06.06a12.07 12.058 0 0 0 7.27-9.4c.13-.77.13-2.58 0-3.4a11.96 11.948 0 0 0-5.73-8.578c-.7-.42-2.05-1.06-2.25-1.06Z"/>
                                            </Viewbox>
                                            <TextBlock Text="Modrinth" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <RadioButton x:Name="SrcCurseForge" Classes="segment" GroupName="contentsrc">
                                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <Viewbox Width="14" Height="14" VerticalAlignment="Center" Opacity="0.5">
                                                <Path Fill="#F16436" Data="M18.326 9.215s4.9-.773 5.674-3.027h-7.507V4.4H0l2.032 2.358v2.415s5.127-.266 7.11 1.237c2.714 2.516-3.053 5.917-3.053 5.917l-.99 3.273c1.547-1.473 4.494-3.377 9.899-3.286c-2.057.65-4.125 1.665-5.735 3.286h10.925l-1.029-3.273s-7.918-4.668-.833-7.112"/>
                                            </Viewbox>
                                            <TextBlock x:Name="SrcCurseForgeLabel" Text="CurseForge" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </RadioButton>
                                </StackPanel>
                            </Border>
                            <!-- Big search field with an inline magnifier, Modrinth-style; the wrapper
                                 border lights up via :focus-within while the inner TextBox stays bare. -->
                            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                                <Border Grid.Column="0" Classes="searchwrap" Background="{DynamicResource BgInput}"
                                        BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1"
                                        CornerRadius="{DynamicResource RadiusMd}" Padding="12,0" MinHeight="38">
                                    <DockPanel VerticalAlignment="Center">
                                        <Image DockPanel.Dock="Left" Width="16" Height="16" Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               Source="{icon:LucideImage Kind=Search, Brush={StaticResource TextMuted}}"/>
                                        <TextBox x:Name="ModrinthQueryBox" Classes="bare" Watermark="Search Modrinth..."
                                                 VerticalContentAlignment="Center" MinHeight="34"/>
                                    </DockPanel>
                                </Border>
                                <Button Grid.Column="1" x:Name="ModrinthSearchButton" Classes="secondary"
                                        Content="Search" Margin="8,0,0,0" VerticalAlignment="Stretch"/>
                            </Grid>
                            <TextBlock DockPanel.Dock="Top" x:Name="ModrinthStatus" Classes="Caption"
                                       Margin="2,0,0,6" TextTrimming="CharacterEllipsis" Text=""/>
                            <!-- Advanced: pick a specific version for the selected result. -->
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
                                <TextBlock x:Name="LblModVersion" Text="Version:" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}"/>
                                <ComboBox x:Name="ModrinthVersionCombo" Width="230"/>
                                <Button x:Name="ModrinthDownloadButton" Classes="ghost" Content="Download to instance"/>
                            </StackPanel>
                            <Grid>
                                <ListBox x:Name="ModrinthList" Background="Transparent" BorderThickness="0" Padding="0,0,8,0"
                                         behaviors:SmoothScroll.Enabled="True"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <!-- Non-virtualized: containers are created once and never recycled,
                                         so hover/scroll can't blink cards or replay the fade. -->
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.Styles>
                                        <Style Selector="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,8"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Style>
                                        <Style Selector="ListBoxItem:selected Border.card">
                                            <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                        </Style>
                                    </ListBox.Styles>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ModrinthHitVm">
                                            <Border Classes="card flat" Padding="10" MinHeight="84" Opacity="{Binding CardOpacity}">
                                                <Grid ColumnDefinitions="Auto,10,*,10,Auto">
                                                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="10"
                                                            Background="{DynamicResource BgElevated}" ClipToBounds="True">
                                                        <Panel>
                                                            <Image Width="22" Height="22"
                                                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                 IsVisible="{Binding !HasIcon}" Source="{icon:LucideImage Kind=Package, Brush={StaticResource TextMuted}}"/>
                                                            <Image Source="{Binding Icon}" Stretch="UniformToFill"
                                                                   IsVisible="{Binding HasIcon}"/>
                                                        </Panel>
                                                    </Border>
                                                    <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Classes="Subtitle" Text="{Binding Title}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Classes="Caption" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource TextMuted}" Text="{Binding Author}"/>
                                                        </StackPanel>
                                                        <TextBlock Classes="Caption" Text="{Binding Description}"
                                                                   TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <Image Width="11" Height="11" VerticalAlignment="Center"
                                                                   Source="{icon:LucideImage Kind=Download, Brush={StaticResource TextMuted}}"/>
                                                            <TextBlock Classes="Caption" Foreground="{DynamicResource TextMuted}"
                                                                       Text="{Binding DownloadsText}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Panel Grid.Column="4" VerticalAlignment="Center" MinWidth="96">
                                                        <Button Classes="primary" HorizontalAlignment="Center"
                                                                Content="Install" IsVisible="{Binding CanInstall}"
                                                                Click="OnModrinthInstallClick"/>
                                                        <ProgressBar Width="70" Height="4" IsIndeterminate="True"
                                                                     VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                     IsVisible="{Binding Installing}"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding Installed}"
                                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Image Width="16" Height="16"
                                                                                 VerticalAlignment="Center" Source="{icon:LucideImage Kind=Check, Brush={StaticResource Success}}"/>
                                                            <TextBlock Classes="Caption" Text="{Binding InstalledLabel}"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource Success}"/>
                                                        </StackPanel>
                                                    </Panel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <StackPanel x:Name="ModrinthEmptyState" IsVisible="False"
                                            VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                                    <Border Width="72" Height="72" CornerRadius="999" HorizontalAlignment="Center"
                                            Background="{DynamicResource BgElevated}">
                                        <Image Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Source="{icon:LucideImage Kind=Search, Brush={StaticResource TextMuted}}"/>
                                    </Border>
                                    <TextBlock x:Name="ModrinthEmptyText" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondary}" Text="Search for mods"/>
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </Grid>
                </DockPanel>

                <!-- =============================== ACCOUNTS (unified) =============================== -->
                <!-- One account = one playable identity. The card list on the left is the selector
                     (offline + Microsoft together); the editor on the right adapts per account
                     (offline = editable skin/nick; Microsoft = read-only Mojang skin). -->
                <ScrollViewer x:Name="AccountsPanel" IsVisible="False"
                              behaviors:SmoothScroll.Enabled="True">
                    <StackPanel Margin="24" Spacing="16" MaxWidth="1180"
                                HorizontalAlignment="Stretch">

                        <!-- Add-account bar -->
                        <Border Classes="card" Padding="18">
                            <Grid ColumnDefinitions="Auto,16,*,Auto" VerticalAlignment="Center">
                                <Border Grid.Column="0" Width="46" Height="46" CornerRadius="12"
                                        Background="{DynamicResource AccentSubtle}"
                                        BorderBrush="{DynamicResource AccentOutline}" BorderThickness="1"
                                        VerticalAlignment="Center">
                                    <Image Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Source="{icon:LucideImage Kind=User, Brush={StaticResource TextSecondary}}"/>
                                </Border>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock x:Name="LblSkinAccountHeader" Classes="Subtitle" Text="Accounts"/>
                                    <TextBlock x:Name="AccountStatus" Text=""
                                               Foreground="{DynamicResource TextSecondary}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8"
                                            VerticalAlignment="Center">
                                    <Button x:Name="AddOfflineButton" Classes="secondary" Content="Add offline account"/>
                                    <Button x:Name="MicrosoftLoginButton" Classes="primary">
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Grid Width="15" Height="15" ColumnDefinitions="7,1,7" RowDefinitions="7,1,7">
                                                <Border Grid.Row="0" Grid.Column="0" Background="#F25022"/>
                                                <Border Grid.Row="0" Grid.Column="2" Background="#7FBA00"/>
                                                <Border Grid.Row="2" Grid.Column="0" Background="#00A4EF"/>
                                                <Border Grid.Row="2" Grid.Column="2" Background="#FFB900"/>
                                            </Grid>
                                            <TextBlock x:Name="MicrosoftLoginLabel" Text="Add Microsoft account"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Two columns: card selector | editor for the selected account -->
                        <Grid ColumnDefinitions="360,20,*">

                            <!-- Left: the account cards (the selector) -->
                            <Border Grid.Column="0" Classes="card" Padding="18" VerticalAlignment="Top">
                                <StackPanel Spacing="14">
                                    <TextBlock x:Name="LblSkinProfileHeader" Classes="Subtitle" Text="Your accounts"/>
                                    <ListBox x:Name="AccountsList" Background="Transparent" Padding="2"
                                             behaviors:SmoothScroll.Enabled="True" MaxHeight="480"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.Styles>
                                            <Style Selector="ListBoxItem">
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="0,0,0,10"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Style>
                                            <Style Selector="ListBoxItem:selected Border.card">
                                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                                <Setter Property="Background" Value="{DynamicResource AccentSubtle}"/>
                                            </Style>
                                        </ListBox.Styles>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:AccountCardVm">
                                                <Border Classes="card flat" Padding="12" MinHeight="66">
                                                    <Grid ColumnDefinitions="Auto,12,*,Auto">
                                                        <!-- Composited head avatar: base face + hat overlay -->
                                                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="8"
                                                                ClipToBounds="True" VerticalAlignment="Center"
                                                                Background="{DynamicResource BgElevated}">
                                                            <Panel>
                                                                <Image Width="20" Height="20" HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       IsVisible="{Binding !HasFace}"
                                                                       Source="{icon:LucideImage Kind=User, Brush={StaticResource TextMuted}}"/>
                                                                <Image Source="{Binding Face}" Stretch="Uniform"
                                                                       RenderOptions.BitmapInterpolationMode="None"/>
                                                                <Image Source="{Binding Hat}" Stretch="Uniform"
                                                                       RenderOptions.BitmapInterpolationMode="None"/>
                                                            </Panel>
                                                        </Border>
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                                                            <TextBlock Text="{Binding Username}" Classes="Body"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding Badge}" Classes="Caption"
                                                                       Foreground="{DynamicResource TextMuted}"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="3" Width="9" Height="9" CornerRadius="999"
                                                                VerticalAlignment="Center" Margin="6,0,2,0"
                                                                Background="{DynamicResource Accent}"
                                                                IsVisible="{Binding IsActive}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <TextBlock x:Name="AccountsEmpty" Text="No accounts yet" IsVisible="False"
                                               HorizontalAlignment="Center" Margin="0,8"
                                               Foreground="{DynamicResource TextMuted}"/>
                                    <Button x:Name="DeleteAccountButton" Classes="secondary" Content="Delete"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                            <!-- Right: editor for the selected account -->
                            <Border Grid.Column="2" Classes="card" Padding="20">
                                <Panel>
                                    <TextBlock x:Name="AccountSelectHint" Text="Select an account to edit it."
                                               Foreground="{DynamicResource TextMuted}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                    <StackPanel x:Name="EditorPanel" IsVisible="False">
                                        <Grid ColumnDefinitions="*,24,Auto">
                                            <StackPanel Grid.Column="0" Spacing="18">

                                                <!-- Identity -->
                                                <StackPanel Spacing="10">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock x:Name="LblProfileName" Text="Nick:" VerticalAlignment="Center"/>
                                                        <TextBox x:Name="ProfileNameBox" Width="220"/>
                                                    </StackPanel>
                                                    <CheckBox x:Name="SlimCheck" Content="Slim model (Alex)"/>
                                                    <TextBlock x:Name="LblNickHint" Classes="Caption" Text="" TextWrapping="Wrap"
                                                               Foreground="{DynamicResource TextMuted}"/>
                                                    <Button x:Name="SaveProfileButton" Classes="primary" Content="Save account"
                                                            HorizontalAlignment="Left"/>
                                                </StackPanel>

                                                <Border Height="1" Background="{DynamicResource BorderSubtle}"/>

                                                <!-- Appearance -->
                                                <StackPanel Spacing="10">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Image Width="17" Height="17" VerticalAlignment="Center"
                                                               Source="{icon:LucideImage Kind=Palette, Brush={StaticResource TextSecondary}}"/>
                                                        <TextBlock x:Name="LblSkinAppearanceHeader" Classes="Subtitle"
                                                                   Text="Skin and cape" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Button x:Name="ChooseSkinButton" Content="Choose skin (PNG)"/>
                                                        <Button x:Name="ChooseCapeButton" Classes="secondary" Content="Choose cape"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="MsManagedNote" IsVisible="False" TextWrapping="Wrap"
                                                               Classes="Caption" Foreground="{DynamicResource TextMuted}" Text=""/>
                                                </StackPanel>

                                                <Border Height="1" Background="{DynamicResource BorderSubtle}"/>

                                                <!-- Apply in-game -->
                                                <StackPanel Spacing="10">
                                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                        <Image Width="17" Height="17" VerticalAlignment="Center"
                                                               Source="{icon:LucideImage Kind=Play, Brush={StaticResource TextSecondary}}"/>
                                                        <TextBlock x:Name="LblApplyInstance" Text="Apply in-game (offline) on instance:"
                                                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                        <Border Background="{DynamicResource BgElevated}" CornerRadius="999"
                                                                BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1"
                                                                Padding="12,6" VerticalAlignment="Center">
                                                            <TextBlock x:Name="SkinInstanceName" Text="—" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource TextSecondary}"/>
                                                        </Border>
                                                        <Button x:Name="ApplySkinButton" Classes="primary" Content="Apply in-game"/>
                                                        <ComboBox x:Name="SkinInstanceCombo" IsVisible="False" Width="0"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="SkinStatus" Text="" TextWrapping="Wrap"
                                                               Foreground="{DynamicResource TextSecondary}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Live previews -->
                                            <Border Grid.Column="2" Background="{DynamicResource BgElevated}" CornerRadius="14"
                                                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1"
                                                    Padding="18" VerticalAlignment="Top">
                                                <StackPanel Spacing="16" HorizontalAlignment="Center">
                                                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                                                        <TextBlock x:Name="LblFacePreview" Text="Face (8x8)"
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="{DynamicResource TextSecondary}"/>
                                                        <Border CornerRadius="10" ClipToBounds="True" Padding="6"
                                                                Background="{DynamicResource BgSurface}"
                                                                BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1">
                                                            <Image x:Name="FaceImage" Width="120" Height="120"
                                                                   Stretch="Uniform" RenderOptions.BitmapInterpolationMode="None"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                                                        <TextBlock x:Name="LblCapePreview" Text="Cape"
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="{DynamicResource TextSecondary}"/>
                                                        <Border CornerRadius="10" ClipToBounds="True" Padding="6"
                                                                Background="{DynamicResource BgSurface}"
                                                                BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1">
                                                            <Image x:Name="CapeImage" Width="140" Height="72"
                                                                   Stretch="Uniform" RenderOptions.BitmapInterpolationMode="None"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                                                        <TextBlock x:Name="LblSkinPreview" Text="Skin (raw PNG)"
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="{DynamicResource TextSecondary}"/>
                                                        <Border CornerRadius="10" ClipToBounds="True" Padding="6"
                                                                Background="{DynamicResource BgSurface}"
                                                                BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1">
                                                            <Image x:Name="SkinImage" Width="110" Height="110"
                                                                   Stretch="Uniform" RenderOptions.BitmapInterpolationMode="None"/>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Panel>
                            </Border>
                        </Grid>

                        <!-- How it works (DockPanel so the help text wraps instead of overflowing) -->
                        <Border Classes="card">
                            <DockPanel LastChildFill="True">
                                <Border DockPanel.Dock="Left" Width="36" Height="36" CornerRadius="10" VerticalAlignment="Top"
                                        Margin="0,0,12,0"
                                        Background="{DynamicResource AccentSubtle}"
                                        BorderBrush="{DynamicResource AccentOutline}" BorderThickness="1">
                                    <Image Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Source="{icon:LucideImage Kind=Info, Brush={StaticResource TextSecondary}}"/>
                                </Border>
                                <StackPanel Spacing="6">
                                    <TextBlock x:Name="LblSkinHelp1" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextSecondary}" Text=""/>
                                    <TextBlock x:Name="LblSkinHelp2" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMuted}" Text=""/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- =============================== SETTINGS (about + prefs) =============================== -->
                <!-- Card-grouped like Accounts: About & preferences / Java / Logs. -->
                <ScrollViewer x:Name="SettingsPanel" IsVisible="False"
                              behaviors:SmoothScroll.Enabled="True">
                    <StackPanel Margin="24" Spacing="16">
                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <TextBlock x:Name="AboutTitle" Classes="Display" Text="FURY Launcher"/>
                                <TextBlock x:Name="AboutVersion" Classes="Mono" Text="version" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock x:Name="AboutCopyright" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" Text=""/>
                                <TextBlock x:Name="AboutContact" TextWrapping="Wrap" Foreground="{DynamicResource TextMuted}" Text=""/>
                                <Border Height="1" Background="{DynamicResource BorderSubtle}" Margin="0,6"/>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock x:Name="LblLanguage" Text="Language:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="LanguageCombo" Width="180"/>
                                    <Button x:Name="CheckUpdatesButton" Content="Check for updates" Margin="14,0,0,0"/>
                                    <TextBlock x:Name="UpdateCheckStatus" Text="" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Java: detect real runtimes, pick a default, or install a Temurin JRE. -->
                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8"><Image Width="17" Height="17" VerticalAlignment="Center" Source="{icon:LucideImage Kind=Coffee, Brush={StaticResource TextSecondary}}"/><TextBlock x:Name="LblJavaSection" Classes="Subtitle" Text="Java" VerticalAlignment="Center"/></StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button x:Name="DetectJavaButton" Content="Detect / fix Java"/>
                                    <ComboBox x:Name="DefaultJavaCombo" Width="360" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock x:Name="LblInstallJava" Text="Install Java:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="JavaInstallCombo" Width="140" VerticalAlignment="Center"/>
                                    <Button x:Name="InstallJavaButton" Classes="secondary" Content="Install"/>
                                </StackPanel>
                                <TextBlock x:Name="JavaStatus" Text="" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock x:Name="JavaOracleWarn" Text="" TextWrapping="Wrap" IsVisible="False" Foreground="{DynamicResource Warning}"/>
                            </StackPanel>
                        </Border>

                        <!-- Logs: mirrors the session log and points at the crash.log folder. -->
                        <Border Classes="card">
                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"><Image Width="17" Height="17" VerticalAlignment="Center" Source="{icon:LucideImage Kind=FileText, Brush={StaticResource TextSecondary}}"/><TextBlock x:Name="LblLogsSection" Classes="Subtitle" Text="Logs" VerticalAlignment="Center"/></StackPanel>
                                <Button Grid.Column="1" x:Name="OpenLogsFolderButton" Classes="secondary"
                                        Content="Open folder" Margin="0,0,6,0"/>
                                <Button Grid.Column="2" x:Name="CopyLogButton" Classes="secondary" Content="Copy"/>
                            </Grid>
                            <Border Background="{DynamicResource BgSurface}" BorderBrush="{DynamicResource BorderSubtle}"
                                    BorderThickness="1" CornerRadius="8">
                                <TextBox x:Name="SettingsLogBox" Classes="Mono" Height="260" AcceptsReturn="True"
                                         IsReadOnly="True" TextWrapping="NoWrap" Background="Transparent"
                                         BorderThickness="0" VerticalContentAlignment="Top"/>
                            </Border>
                        </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </uic:NavigationView>
    </DockPanel>

        <!-- Animated toast: brief confirmations / errors, fade + slide from the bottom. -->
        <Border x:Name="ToastBorder" IsHitTestVisible="False" Opacity="0"
                VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,30"
                Background="{DynamicResource BgElevated}" BorderThickness="1"
                BorderBrush="{DynamicResource Accent}" CornerRadius="10" Padding="16,11"
                MaxWidth="560" BoxShadow="0 8 26 0 #70000000">
            <Border.RenderTransform>
                <TranslateTransform Y="24">
                    <TranslateTransform.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Y" Duration="0:0:0.24" Easing="CubicEaseOut"/>
                        </Transitions>
                    </TranslateTransform.Transitions>
                </TranslateTransform>
            </Border.RenderTransform>
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.24"/>
                </Transitions>
            </Border.Transitions>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Image x:Name="ToastIcon" Width="18" Height="18"
                                     VerticalAlignment="Center" Source="{icon:LucideImage Kind=Info, Brush={StaticResource Accent}}"/>
                <TextBlock x:Name="ToastText" VerticalAlignment="Center" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextPrimary}"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:AppWindow>
