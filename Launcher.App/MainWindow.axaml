<ui:AppWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="using:FluentAvalonia.UI.Windowing"
        xmlns:uic="using:FluentAvalonia.UI.Controls"
        xmlns:icon="using:IconPacks.Avalonia.Lucide"
        xmlns:models="using:Launcher.Core.Models"
        xmlns:vm="using:Launcher.App.ViewModels"
        x:Class="Launcher.App.MainWindow"
        Width="1280" Height="860"
        MinWidth="1120" MinHeight="740"
        Background="{DynamicResource BgBase}"
        Foreground="{DynamicResource TextPrimary}"
        FontWeight="SemiBold"
        Title="FURY Launcher">

    <!-- Visible text is set from Launcher.Core.Localization at runtime (ApplyLanguage). -->
    <DockPanel>

        <!-- Auto-update banner: hidden until a newer release is found on GitHub. -->
        <Border x:Name="UpdateBanner" DockPanel.Dock="Top" IsVisible="False"
                Background="{DynamicResource BgElevated}" BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,0,1" Padding="16,11">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="⬆" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock x:Name="UpdateBannerText" Grid.Column="1" Foreground="{DynamicResource TextPrimary}"
                           FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap"/>
                <Button x:Name="UpdateButton" Grid.Column="2" Classes="primary" Content="Update"
                        Padding="16,7" Margin="12,0,8,0"/>
                <Button x:Name="UpdateDismissButton" Grid.Column="3" Classes="ghost" Content="Later"
                        Padding="12,7"/>
            </Grid>
        </Border>

        <uic:NavigationView x:Name="NavView" PaneDisplayMode="Left" OpenPaneLength="220"
                            IsSettingsVisible="False" IsBackButtonVisible="False">

            <uic:NavigationView.PaneHeader>
                <StackPanel Margin="8,10,8,14" Spacing="0">
                    <TextBlock Text="FURY" FontFamily="{DynamicResource FontUi}" FontSize="24"
                               FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock x:Name="NavVersion" Classes="Mono" Text="" FontSize="12"
                               Foreground="{DynamicResource TextMuted}"/>
                </StackPanel>
            </uic:NavigationView.PaneHeader>

            <uic:NavigationView.MenuItems>
                <uic:NavigationViewItem x:Name="NavHome" Content="Home">
                    <uic:NavigationViewItem.IconSource>
                        <uic:ImageIconSource Source="{icon:LucideImage Kind=LayoutGrid, Brush={StaticResource TextSecondary}}"/>
                    </uic:NavigationViewItem.IconSource>
                </uic:NavigationViewItem>
                <uic:NavigationViewItem x:Name="NavMods" Content="Mods">
                    <uic:NavigationViewItem.IconSource>
                        <uic:ImageIconSource Source="{icon:LucideImage Kind=Package, Brush={StaticResource TextSecondary}}"/>
                    </uic:NavigationViewItem.IconSource>
                </uic:NavigationViewItem>
                <uic:NavigationViewItem x:Name="NavAccounts" Content="Accounts">
                    <uic:NavigationViewItem.IconSource>
                        <uic:ImageIconSource Source="{icon:LucideImage Kind=User, Brush={StaticResource TextSecondary}}"/>
                    </uic:NavigationViewItem.IconSource>
                </uic:NavigationViewItem>
            </uic:NavigationView.MenuItems>

            <uic:NavigationView.FooterMenuItems>
                <uic:NavigationViewItem x:Name="NavSettings" Content="Settings">
                    <uic:NavigationViewItem.IconSource>
                        <uic:ImageIconSource Source="{icon:LucideImage Kind=Settings, Brush={StaticResource TextSecondary}}"/>
                    </uic:NavigationViewItem.IconSource>
                </uic:NavigationViewItem>
            </uic:NavigationView.FooterMenuItems>

            <!-- One content host; sections toggle visibility from NavView.SelectionChanged. -->
            <Grid Margin="0">

                <!-- ============================ HOME (instances + play) ============================ -->
                <Grid x:Name="HomePanel" Margin="24">
                    <DockPanel>
                        <!-- Header: title + instance-level actions -->
                        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                            <TextBlock Grid.Column="0" x:Name="LblInstances" Classes="Title"
                                       Text="Instances" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button x:Name="ImportPackButton" Classes="secondary" Content="Import .frpack"/>
                                <Button x:Name="ImportMrpackButton" Classes="secondary" Content="Import .mrpack"/>
                                <Button x:Name="RefreshInstancesButton" Classes="secondary" Content="Refresh"/>
                                <Button x:Name="AddInstanceButton" Classes="primary">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <icon:PackIconLucide Kind="Plus" Width="16" Height="16" VerticalAlignment="Center"
                                                             Foreground="{DynamicResource OnAccent}"/>
                                        <TextBlock x:Name="AddInstanceLabel" Text="New instance" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Hero: the selected instance + the big PLAY button (bottom band) -->
                        <Border DockPanel.Dock="Bottom" Classes="card" x:Name="HeroCard" Margin="0,16,0,0">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="HeroName" Classes="Display" Text="—" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="HeroMeta" Classes="Caption"
                                                   Foreground="{DynamicResource TextSecondary}" Text=""/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button x:Name="EditInstanceButton" Classes="secondary" Content="Edit" MinHeight="48"/>
                                        <Button x:Name="OpenFolderButton" Classes="secondary" Content="Folder" MinHeight="48"/>
                                        <Button x:Name="ExportPackButton" Classes="secondary" Content="Export" MinHeight="48"/>
                                        <Button x:Name="DeleteInstanceButton" Classes="secondary" Content="Delete" MinHeight="48"/>
                                        <Button x:Name="StopButton" Classes="secondary" Content="Stop" MinHeight="48"/>
                                        <Button x:Name="PlayButton" Classes="primary" MinHeight="48" Padding="34,0">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <icon:PackIconLucide Kind="Play" Width="20" Height="20" VerticalAlignment="Center"
                                                                     Foreground="{DynamicResource OnAccent}"/>
                                                <TextBlock x:Name="PlayButtonLabel" Text="PLAY" FontSize="18" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock x:Name="LblProfileOffline" Text="Profile:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="OfflineProfileCombo" Width="220"/>
                                    <!-- Hidden: kept in sync with the card grid so play logic is unchanged. -->
                                    <ComboBox x:Name="PlayInstanceCombo" IsVisible="False" Width="0"/>
                                </StackPanel>
                                <ProgressBar x:Name="DownloadProgress" Minimum="0" Maximum="1" Height="6"/>
                                <TextBlock x:Name="PlayStatus" Classes="Caption" Text="" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                        </Border>

                        <!-- Log drawer: collapsed by default; opens automatically on error. -->
                        <Expander x:Name="LogDrawer" DockPanel.Dock="Bottom" IsExpanded="False"
                                  Margin="0,12,0,0" HorizontalAlignment="Stretch">
                            <Expander.Header>
                                <TextBlock x:Name="LblLog" Text="Log"/>
                            </Expander.Header>
                            <TextBox x:Name="LogBox" Classes="Mono" Height="180" AcceptsReturn="True" IsReadOnly="True"
                                     TextWrapping="NoWrap" VerticalContentAlignment="Top"/>
                        </Expander>

                        <!-- Instance cards grid (fills remaining space) -->
                        <Grid>
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                                <ListBox x:Name="InstancesList" Background="Transparent" BorderThickness="0" Padding="0">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.Styles>
                                        <Style Selector="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,12,12"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Style>
                                        <!-- Selected card: 1px accent border + subtle tint, not a full purple fill. -->
                                        <Style Selector="ListBoxItem:selected Border.card">
                                            <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                            <Setter Property="Background" Value="{DynamicResource AccentSubtle}"/>
                                        </Style>
                                    </ListBox.Styles>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:Instance">
                                            <Border Classes="card" Width="196" Padding="14">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Classes="Subtitle" Text="{Binding Name}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Border Background="{DynamicResource BgElevated}" CornerRadius="4"
                                                            Padding="6,2" HorizontalAlignment="Left">
                                                        <TextBlock Classes="Caption"
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   Text="{Binding Loader}"/>
                                                    </Border>
                                                    <TextBlock Classes="Caption" Foreground="{DynamicResource TextMuted}"
                                                               Text="{Binding McVersion}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </ScrollViewer>
                            <StackPanel x:Name="InstancesEmptyState" IsVisible="False"
                                        VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                                <icon:PackIconLucide Kind="LayoutGrid" Width="40" Height="40"
                                                     HorizontalAlignment="Center" Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock x:Name="EmptyStateText" Text="No instances yet"
                                           HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                                <Button x:Name="EmptyStateNewButton" Classes="primary" Content="＋ New instance"
                                        HorizontalAlignment="Center" Padding="18,10" FontSize="15"/>
                            </StackPanel>
                        </Grid>
                    </DockPanel>

                    <!-- Create / edit instance overlay (hidden until +New or Edit) -->
                    <Grid x:Name="InstanceOverlay" IsVisible="False" Background="#B3000000">
                        <Border Classes="card" Width="480" MaxHeight="640"
                                VerticalAlignment="Center" HorizontalAlignment="Center" Padding="22">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" x:Name="OverlayTitle" Classes="Title"
                                           Text="New instance" Margin="0,0,0,14"/>
                                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
                                    <Button x:Name="CancelInstanceButton" Classes="secondary" Content="Cancel"/>
                                    <Button x:Name="NewInstanceButton" Classes="primary" Content="Create"/>
                                    <Button x:Name="SaveInstanceButton" Classes="primary" Content="Save"/>
                                </StackPanel>
                                <ScrollViewer>
                                    <StackPanel Spacing="14">
                                        <TextBlock x:Name="LblSecGeneral" Classes="Subtitle" Text="General"/>
                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="LblName" Text="Name" Foreground="{DynamicResource TextSecondary}"/>
                                            <TextBox x:Name="NameBox"/>
                                            <TextBlock x:Name="LblMcVersion" Text="Minecraft version" Foreground="{DynamicResource TextSecondary}"/>
                                            <ComboBox x:Name="McVersionCombo" HorizontalAlignment="Stretch"/>
                                            <TextBlock x:Name="LblLoader" Text="Loader" Foreground="{DynamicResource TextSecondary}"/>
                                            <ComboBox x:Name="LoaderCombo" HorizontalAlignment="Stretch"/>
                                        </StackPanel>

                                        <TextBlock x:Name="LblSecMemory" Classes="Subtitle" Text="Memory &amp; Java"/>
                                        <StackPanel Spacing="6">
                                            <Grid ColumnDefinitions="*,12,*">
                                                <StackPanel Grid.Column="0" Spacing="6">
                                                    <TextBlock x:Name="LblMinRam" Text="Min RAM (MB)" Foreground="{DynamicResource TextSecondary}"/>
                                                    <TextBox x:Name="MinRamBox" Text="512"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Spacing="6">
                                                    <TextBlock x:Name="LblMaxRam" Text="Max RAM (MB)" Foreground="{DynamicResource TextSecondary}"/>
                                                    <TextBox x:Name="MaxRamBox" Text="2048"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock x:Name="LblJvmArgs" Text="JVM arguments (space-separated)" Foreground="{DynamicResource TextSecondary}"/>
                                            <TextBox x:Name="JvmArgsBox" Classes="Mono"/>
                                            <TextBlock x:Name="LblJavaPath" Text="Java path (empty = managed)" Foreground="{DynamicResource TextSecondary}"/>
                                            <ComboBox x:Name="JavaCombo" HorizontalAlignment="Stretch" Margin="0,0,0,4"/>
                                            <DockPanel>
                                                <Button x:Name="BrowseJavaButton" Content="..." DockPanel.Dock="Right" Margin="6,0,0,0"/>
                                                <TextBox x:Name="JavaPathBox" Classes="Mono"/>
                                            </DockPanel>
                                        </StackPanel>

                                        <TextBlock x:Name="InstanceStatus" Text="" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- =============================== MODS =============================== -->
                <DockPanel x:Name="ModsPanel" IsVisible="False" Margin="16">
                    <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="LblModInstance" Text="Instance:" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ModsInstanceName" Text="—" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondary}"/>
                            <Button x:Name="RefreshModsButton" Content="Refresh"/>
                            <ComboBox x:Name="ModInstanceCombo" IsVisible="False" Width="0"/>
                        </StackPanel>
                        <StackPanel x:Name="ModsVanillaPanel" Orientation="Horizontal" Spacing="8" IsVisible="False">
                            <TextBlock x:Name="ModsVanillaWarning" Text="" TextWrapping="Wrap"
                                       Foreground="{DynamicResource Danger}" VerticalAlignment="Center" MaxWidth="640"/>
                            <Button x:Name="NewModdedInstanceButton" Classes="primary" Content="Create modded instance"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,12,*">
                        <DockPanel Grid.Column="0">
                            <TextBlock x:Name="LblInstalledMods" DockPanel.Dock="Top" Text="Installed mods:" Margin="0,0,0,4"/>
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
                                <Button x:Name="AddModButton" Content="Add jar"/>
                                <Button x:Name="RemoveModButton" Classes="secondary" Content="Remove"/>
                                <Button x:Name="ToggleModButton" Content="Enable/Disable"/>
                            </StackPanel>
                            <Grid>
                                <ListBox x:Name="ModsList" Background="Transparent" BorderThickness="0" Padding="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.Styles>
                                        <Style Selector="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,8"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Style>
                                        <Style Selector="ListBoxItem:selected Border.card">
                                            <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                            <Setter Property="Background" Value="{DynamicResource AccentSubtle}"/>
                                        </Style>
                                    </ListBox.Styles>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:ModItem">
                                            <Border Classes="card" Padding="10">
                                                <Grid ColumnDefinitions="Auto,10,*,10,Auto">
                                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="6"
                                                            Background="{DynamicResource BgElevated}">
                                                        <icon:PackIconLucide Kind="Package" Width="20" Height="20"
                                                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                             Foreground="{DynamicResource TextMuted}"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="2" Classes="Body" VerticalAlignment="Center"
                                                               Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                                                    <Border Grid.Column="4" CornerRadius="4" Padding="8,3" VerticalAlignment="Center"
                                                            Background="{DynamicResource BgElevated}">
                                                        <Panel>
                                                            <TextBlock Classes="Caption" Text="ON" IsVisible="{Binding Enabled}"
                                                                       Foreground="{DynamicResource Success}"/>
                                                            <TextBlock Classes="Caption" Text="OFF" IsVisible="{Binding !Enabled}"
                                                                       Foreground="{DynamicResource TextMuted}"/>
                                                        </Panel>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <StackPanel x:Name="ModsEmptyState" IsVisible="False"
                                            VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                    <icon:PackIconLucide Kind="Package" Width="30" Height="30"
                                                         HorizontalAlignment="Center" Foreground="{DynamicResource TextMuted}"/>
                                    <TextBlock x:Name="ModsEmptyText" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondary}" Text="No mods installed"/>
                                </StackPanel>
                            </Grid>
                        </DockPanel>

                        <DockPanel Grid.Column="2">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                                <TextBox x:Name="ModrinthQueryBox" Width="240" Watermark="Search Modrinth..."/>
                                <Button x:Name="ModrinthSearchButton" Classes="secondary" Content="Search"/>
                                <TextBlock x:Name="ModrinthStatus" Classes="Caption" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" Text=""/>
                            </StackPanel>
                            <!-- Advanced: pick a specific version for the selected result. -->
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
                                <TextBlock x:Name="LblModVersion" Text="Version:" VerticalAlignment="Center"/>
                                <ComboBox x:Name="ModrinthVersionCombo" Width="230"/>
                                <Button x:Name="ModrinthDownloadButton" Classes="secondary" Content="Download to instance"/>
                            </StackPanel>
                            <Grid>
                                <ListBox x:Name="ModrinthList" Background="Transparent" BorderThickness="0" Padding="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.Styles>
                                        <Style Selector="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,8"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Style>
                                        <Style Selector="ListBoxItem:selected Border.card">
                                            <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                        </Style>
                                    </ListBox.Styles>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ModrinthHitVm">
                                            <Border Classes="card" Padding="10">
                                                <Grid ColumnDefinitions="Auto,10,*,10,Auto">
                                                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="6"
                                                            Background="{DynamicResource BgElevated}" ClipToBounds="True">
                                                        <Panel>
                                                            <icon:PackIconLucide Kind="Package" Width="22" Height="22"
                                                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                 Foreground="{DynamicResource TextMuted}"
                                                                                 IsVisible="{Binding !HasIcon}"/>
                                                            <Image Source="{Binding Icon}" Stretch="UniformToFill"
                                                                   IsVisible="{Binding HasIcon}"/>
                                                        </Panel>
                                                    </Border>
                                                    <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Classes="Subtitle" Text="{Binding Title}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Classes="Caption" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource TextMuted}" Text="{Binding Author}"/>
                                                        </StackPanel>
                                                        <TextBlock Classes="Caption" Text="{Binding Description}"
                                                                   TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Classes="Caption" Foreground="{DynamicResource TextMuted}"
                                                                   Text="{Binding DownloadsText}"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="4" Classes="primary" x:Name="InstallHitButton"
                                                            VerticalAlignment="Center" Content="Install"
                                                            IsEnabled="{Binding !Installing}"
                                                            Click="OnModrinthInstallClick"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <StackPanel x:Name="ModrinthEmptyState" IsVisible="False"
                                            VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                                    <icon:PackIconLucide Kind="Package" Width="34" Height="34"
                                                         HorizontalAlignment="Center" Foreground="{DynamicResource TextMuted}"/>
                                    <TextBlock x:Name="ModrinthEmptyText" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondary}" Text="Search for mods"/>
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </Grid>
                </DockPanel>

                <!-- =============================== ACCOUNTS (login + skin) =============================== -->
                <ScrollViewer x:Name="AccountsPanel" IsVisible="False">
                    <StackPanel Margin="16" Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="MicrosoftLoginButton" Classes="primary" Content="Microsoft login"/>
                            <Button x:Name="MicrosoftLogoutButton" Classes="secondary" Content="Log out"/>
                            <TextBlock x:Name="AccountStatus" VerticalAlignment="Center" Text="(offline)"
                                       Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock x:Name="LblSkinProfile" Text="Profile:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="SkinProfileCombo" Width="200"/>
                            <Button x:Name="NewProfileButton" Content="New"/>
                            <Button x:Name="DeleteProfileButton" Classes="secondary" Content="Delete"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock x:Name="LblProfileName" Text="Nick:" VerticalAlignment="Center"/>
                            <TextBox x:Name="ProfileNameBox" Width="180"/>
                            <CheckBox x:Name="SlimCheck" Content="Slim model (Alex)"/>
                            <Button x:Name="SaveProfileButton" Content="Save profile"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button x:Name="ChooseSkinButton" Content="Choose skin (PNG)"/>
                            <Button x:Name="ChooseCapeButton" Content="Choose cape"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock x:Name="LblApplyInstance" Text="Apply in-game (offline) on instance:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="SkinInstanceCombo" Width="240"/>
                            <Button x:Name="ApplySkinButton" Content="Apply in-game"/>
                        </StackPanel>

                        <Border Classes="card" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="20">
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="LblSkinPreview" Text="Skin (raw PNG)"/>
                                    <Image x:Name="SkinImage" Width="128" Height="128"
                                           Stretch="Uniform" RenderOptions.BitmapInterpolationMode="None"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="LblFacePreview" Text="Face (8x8)"/>
                                    <Image x:Name="FaceImage" Width="128" Height="128"
                                           Stretch="Uniform" RenderOptions.BitmapInterpolationMode="None"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="LblCapePreview" Text="Cape"/>
                                    <Image x:Name="CapeImage" Width="80" Height="128"
                                           Stretch="Uniform" RenderOptions.BitmapInterpolationMode="None"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="SkinStatus" Text="" TextWrapping="Wrap"/>
                        <TextBlock x:Name="LblSkinHelp1" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" Text=""/>
                        <TextBlock x:Name="LblSkinHelp2" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" Text=""/>
                    </StackPanel>
                </ScrollViewer>

                <!-- =============================== SETTINGS (about + prefs) =============================== -->
                <ScrollViewer x:Name="SettingsPanel" IsVisible="False">
                    <StackPanel Margin="16" Spacing="8">
                        <TextBlock x:Name="AboutTitle" Classes="Display" Text="FURY Launcher"/>
                        <TextBlock x:Name="AboutVersion" Classes="Mono" Text="version" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock x:Name="AboutCopyright" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" Text="" Margin="0,6,0,0"/>
                        <TextBlock x:Name="AboutContact" TextWrapping="Wrap" Foreground="{DynamicResource TextMuted}" Text=""/>
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,12,0,0">
                            <TextBlock x:Name="LblLanguage" Text="Language:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="LanguageCombo" Width="180"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
                            <Button x:Name="CheckUpdatesButton" Content="Check for updates"/>
                            <TextBlock x:Name="UpdateCheckStatus" Text="" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Java: detect real runtimes and pick a default, dodging the Oracle stub. -->
                        <StackPanel Spacing="6" Margin="0,20,0,0">
                            <TextBlock x:Name="LblJavaSection" Classes="Subtitle" Text="Java"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button x:Name="DetectJavaButton" Content="Detect / fix Java"/>
                                <ComboBox x:Name="DefaultJavaCombo" Width="360" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="JavaStatus" Text="" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock x:Name="JavaOracleWarn" Text="" TextWrapping="Wrap" IsVisible="False" Foreground="{DynamicResource Warning}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </uic:NavigationView>
    </DockPanel>
</ui:AppWindow>
