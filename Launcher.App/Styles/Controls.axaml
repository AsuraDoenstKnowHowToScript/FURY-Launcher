<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uic="using:FluentAvalonia.UI.Controls">

    <!-- Global text defaults. Text is never the accent colour, always a grey.
         SemiBold weight: lighter weights of Outfit read too thin for low-vision users. -->
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource FontUi}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button">
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="ComboBox">
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="CheckBox">
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Left navigation items: a bit larger + bolder. -->
    <Style Selector="uic|NavigationViewItem">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Height" Value="44"/>
    </Style>

    <!-- ============================ BUTTONS ============================ -->
    <!-- Variants are opt-in via Classes; plain buttons keep the Fluent look.
         Subtle 120ms colour transitions, no glow/shadow/scale. -->

    <!-- primary -->
    <Style Selector="Button.primary">
        <Setter Property="Foreground" Value="{DynamicResource OnAccent}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.primary /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Accent}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
        <Setter Property="Transitions">
            <Transitions><BrushTransition Property="Background" Duration="0:0:0.12"/></Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentHover}"/>
    </Style>
    <Style Selector="Button.primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentPressed}"/>
    </Style>

    <!-- secondary -->
    <Style Selector="Button.secondary">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>
    <Style Selector="Button.secondary /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BgElevated}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
        <Setter Property="Transitions">
            <Transitions><BrushTransition Property="BorderBrush" Duration="0:0:0.12"/></Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.secondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BgElevated}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
    </Style>

    <!-- danger (destructive only: delete instance, remove mod) -->
    <Style Selector="Button.danger">
        <Setter Property="Foreground" Value="{DynamicResource OnAccent}"/>
    </Style>
    <Style Selector="Button.danger /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Danger}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
        <Setter Property="Transitions">
            <Transitions><DoubleTransition Property="Opacity" Duration="0:0:0.12"/></Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Danger}"/>
        <Setter Property="Opacity" Value="0.85"/>
    </Style>

    <!-- ghost -->
    <Style Selector="Button.ghost">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
    </Style>
    <Style Selector="Button.ghost /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BgElevated}"/>
    </Style>

    <!-- ============================ INPUTS ============================ -->

    <Style Selector="TextBox /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource BgInput}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
    </Style>
    <Style Selector="ComboBox /template/ Border#Background">
        <Setter Property="Background" Value="{DynamicResource BgInput}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
    </Style>
    <Style Selector="ComboBox:focus /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
    </Style>

    <!-- ============================ LISTS ============================ -->

    <Style Selector="ListBox">
        <Setter Property="Background" Value="{DynamicResource BgInput}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}"/>
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BgElevated}"/>
    </Style>
    <!-- Selected: subtle accent tint, not the full purple -->
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentSubtle}"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>
    <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentSubtle}"/>
    </Style>

    <!-- ============================ MISC ============================ -->

    <Style Selector="ProgressBar">
        <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
    </Style>

    <!-- Custom sliding toggle (ToggleButton.switch): a track + a knob that slides with a
         TransformOperationsTransition, so the on/off flip is always smooth. Only the track
         colour and the knob position change by state; nothing that changes is set inline
         (inline template values would override the :checked style setters). -->
    <Style Selector="ToggleButton.switch">
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="Track" CornerRadius="12" BorderThickness="1">
                    <Border.Transitions>
                        <Transitions>
                            <BrushTransition Property="Background" Duration="0:0:0.18"/>
                            <BrushTransition Property="BorderBrush" Duration="0:0:0.18"/>
                        </Transitions>
                    </Border.Transitions>
                    <Border Name="Knob" Width="18" Height="18" CornerRadius="9"
                            HorizontalAlignment="Left" VerticalAlignment="Center" Margin="3,0,0,0"
                            Background="#ECEAF3">
                        <Border.Transitions>
                            <Transitions>
                                <TransformOperationsTransition Property="RenderTransform"
                                                               Duration="0:0:0.18" Easing="CubicEaseOut"/>
                            </Transitions>
                        </Border.Transitions>
                    </Border>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="ToggleButton.switch /template/ Border#Track">
        <Setter Property="Background" Value="{DynamicResource BgElevated}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
    </Style>
    <Style Selector="ToggleButton.switch:checked /template/ Border#Track">
        <Setter Property="Background" Value="{DynamicResource Accent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
    </Style>
    <Style Selector="ToggleButton.switch /template/ Border#Knob">
        <Setter Property="RenderTransform" Value="translateX(0px)"/>
    </Style>
    <Style Selector="ToggleButton.switch:checked /template/ Border#Knob">
        <Setter Property="RenderTransform" Value="translateX(20px)"/>
    </Style>

    <!-- Card container: subtle border + a soft drop shadow so cards read as raised. -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusLg}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="BoxShadow" Value="0 2 8 0 #40000000"/>
        <Setter Property="Transitions">
            <Transitions>
                <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.14"/>
            </Transitions>
        </Setter>
    </Style>
    <!-- Lift a card a touch more when the pointer is over it (inside a hoverable list). -->
    <Style Selector="ListBoxItem:pointerover Border.card">
        <Setter Property="BoxShadow" Value="0 4 14 0 #55000000"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
    </Style>

</Styles>
