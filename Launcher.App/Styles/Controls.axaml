<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uic="using:FluentAvalonia.UI.Controls">

    <!-- Global text defaults. Text is NEVER the accent colour — always a grey.
         Medium weight: the Outfit "Normal" weight reads too thin. -->
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource FontUi}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>
    <Style Selector="Button">
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>
    <Style Selector="ComboBox">
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>
    <Style Selector="CheckBox">
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <!-- Left navigation items: a bit larger + bolder. -->
    <Style Selector="uic|NavigationViewItem">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Height" Value="44"/>
    </Style>

    <!-- ============================ BUTTONS ============================ -->
    <!-- Variants are opt-in via Classes; plain buttons keep the Fluent look.
         Subtle 120ms colour transitions, no glow/shadow/scale. -->

    <!-- primary -->
    <Style Selector="Button.primary">
        <Setter Property="Foreground" Value="{DynamicResource OnAccent}"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>
    <Style Selector="Button.primary /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Accent}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
        <Setter Property="Transitions">
            <Transitions><BrushTransition Property="Background" Duration="0:0:0.12"/></Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentHover}"/>
    </Style>
    <Style Selector="Button.primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentPressed}"/>
    </Style>

    <!-- secondary -->
    <Style Selector="Button.secondary">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>
    <Style Selector="Button.secondary /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BgElevated}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
        <Setter Property="Transitions">
            <Transitions><BrushTransition Property="BorderBrush" Duration="0:0:0.12"/></Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.secondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BgElevated}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
    </Style>

    <!-- danger (destructive only: delete instance, remove mod) -->
    <Style Selector="Button.danger">
        <Setter Property="Foreground" Value="{DynamicResource OnAccent}"/>
    </Style>
    <Style Selector="Button.danger /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Danger}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
        <Setter Property="Transitions">
            <Transitions><DoubleTransition Property="Opacity" Duration="0:0:0.12"/></Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Danger}"/>
        <Setter Property="Opacity" Value="0.85"/>
    </Style>

    <!-- ghost -->
    <Style Selector="Button.ghost">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
    </Style>
    <Style Selector="Button.ghost /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BgElevated}"/>
    </Style>

    <!-- ============================ INPUTS ============================ -->

    <Style Selector="TextBox /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource BgInput}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
    </Style>
    <Style Selector="ComboBox /template/ Border#Background">
        <Setter Property="Background" Value="{DynamicResource BgInput}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
    </Style>
    <Style Selector="ComboBox:focus /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
    </Style>

    <!-- ============================ LISTS ============================ -->

    <Style Selector="ListBox">
        <Setter Property="Background" Value="{DynamicResource BgInput}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}"/>
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BgElevated}"/>
    </Style>
    <!-- Selected: subtle accent tint, not the full purple -->
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentSubtle}"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>
    <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentSubtle}"/>
    </Style>

    <!-- ============================ MISC ============================ -->

    <Style Selector="ProgressBar">
        <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
    </Style>

    <!-- Card container -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusLg}"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

</Styles>
