<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Type scale. Apply with Classes="Display" / "Title" / ... on a TextBlock. -->

    <Style Selector="TextBlock.Display">
        <Setter Property="FontFamily" Value="{DynamicResource FontUi}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>

    <Style Selector="TextBlock.Title">
        <Setter Property="FontFamily" Value="{DynamicResource FontUi}"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>

    <Style Selector="TextBlock.Subtitle">
        <Setter Property="FontFamily" Value="{DynamicResource FontUi}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>

    <Style Selector="TextBlock.Body">
        <Setter Property="FontFamily" Value="{DynamicResource FontUi}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>

    <Style Selector="TextBlock.Caption">
        <Setter Property="FontFamily" Value="{DynamicResource FontUi}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
    </Style>

    <!-- Mono: only where technical (log, version, path, JVM args). -->
    <Style Selector="TextBlock.Mono">
        <Setter Property="FontFamily" Value="{DynamicResource FontMono}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>
    <Style Selector="TextBox.Mono">
        <Setter Property="FontFamily" Value="{DynamicResource FontMono}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

</Styles>
